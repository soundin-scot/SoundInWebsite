---
import Layout from '@/layouts/Layout.astro';

const title = 'Vision | SoundIn';
const description = 'SoundIn builds compliance infrastructure for UK nightlife. The Terrorism Act 2025 changes what operators need — we are building it.';

const sections = [
  {
    num: '01',
    heading: 'The problem with nightlife tech',
    body: [
      "Venues run on fragmented tools: clickers for headcount, notebooks for incidents, WhatsApp threads for guest lists, spreadsheets for settlement, email chains for artist logistics. Every tool is a different conversation, a different source of truth.",
      "Artists don't know if the advancing checklist is final. Venues don't know if their incidents are properly logged. Promoters and security have no shared record. When regulatory review happens, there is no unified account of what happened.",
    ],
  },
  {
    num: '02',
    heading: "Connectivity changes the game",
    body: [
      "Holocron is built on one principle: everyone involved in running a night should work from the same record. The booking pipeline connects venues and artists in real time. The settlement record is visible to both parties simultaneously. Incidents logged by security feed the compliance record directly — no bottleneck, no reinterpretation.",
      "The Terrorism (Protection of Premises) Act 2025 requires documented procedures and verifiable records. Holocron makes compliance a side effect of how you already operate, not a separate process. From the first event, the system observes your operation: when peak hours are, where incidents cluster, which staff combinations work best, what revenue comes in. After ten events, it surfaces calibrated guidance—patterns that took months to see, now visible on day twelve.",
    ],
  },
  {
    num: '03',
    heading: "Regenerative scene building",
    body: [
      "Holocron is built to put more value back into the nightlife industry than it extracts. The platform launches with free access for artists, promoters, and security. The shared booking pipeline and unified incident record create value for the entire scene, not just the venue paying the subscription.",
      "Over time, this connected scene graph becomes more valuable: artists see their booking history and reputation, venues understand talent patterns, promoters coordinate without losing records to old group chats. The intelligence Holocron builds is built on participation, not extraction.",
    ],
  },
  {
    num: '04',
    heading: 'One product. One founder.',
    body: [
      "I built this from the Scottish Highlands because that is where I live. Not as a brand story, but as a fact that shapes how I see the work.",
      "Solo doesn't mean small. It means I have to be deliberate — about what goes into the product, about who I work with, about every hour spent. Holocron exists because the venue operators I know needed better tools, and no one was building for the actual shape of their nights.",
      "Say what you mean. Charge what the work costs. Own your mistakes. Take on less so you can do more with it. Build things that outlast the brief. Care about the people on the other side of every contract, and about the communities they operate in.",
    ],
  },
];

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': 'https://soundin.scot/vision#webpage',
  url: 'https://soundin.scot/vision',
  name: title,
  description,
  isPartOf: { '@id': 'https://soundin.scot/#organization' },
};
---

<Layout
  title={title}
  description={description}
  canonical="https://soundin.scot/vision"
  current="vision"
  skipLink={{ href: '#vision-content', label: 'Skip to content' }}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(aboutSchema)} slot="head" />

  <div class="page-hero" id="vision-content" tabindex="-1">
    <div class="page-hero-inner">
      <span class="page-hero-kicker">vision</span>
      <h1 class="page-hero-title">Safer venues.<br />Better nights.</h1>
      <p class="page-hero-desc">Martyn's Law changed what operators need to know. We're building the infrastructure to prove it.</p>
    </div>
  </div>

  <div class="vision-quote-band">
    <blockquote class="vision-quote">
      <p>&ldquo;I&rsquo;d rather do fewer things properly than chase every brief that comes through the door.&rdquo;</p>
      <cite>Cougar Macdougall &mdash; Founder, SoundIn</cite>
    </blockquote>
  </div>

  <div class="vision-body">
    {sections.map((s) => (
      <section class="vsec">
        <header class="vsec-hd">
          <span class="vsec-num">{s.num}</span>
          <h2 class="vsec-title">{s.heading}</h2>
        </header>
        <div class="vsec-text">
          {s.body.map((p) => <p>{p}</p>)}
        </div>
      </section>
    ))}

    <div class="vision-cta">
      <p>Managing a venue?</p>
      <a href="/contact" class="cta-button">Get in touch <span aria-hidden="true">&rarr;</span></a>
    </div>
  </div>
</Layout>

<style>
  .vision-quote-band {
    padding: 88px 64px 72px;
    max-width: 960px;
    margin: 0 auto;
  }

  .vision-quote p {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    font-size: clamp(26px, 3.8vw, 50px);
    line-height: 1.2;
    color: var(--color-snow);
    margin-bottom: 20px;
    text-wrap: balance;
  }

  .vision-quote cite {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-style: normal;
  }

  .vision-body {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 64px 120px;
    border-top: 1px solid var(--color-ghost);
  }

  .vsec {
    padding: 60px 0;
    border-bottom: 1px solid var(--color-ghost);
  }

  .vsec-hd {
    display: flex;
    align-items: baseline;
    gap: 20px;
    margin-bottom: 24px;
  }

  .vsec-num {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    font-size: 22px;
    color: var(--color-salmon);
    flex-shrink: 0;
  }

  .vsec-title {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    font-size: clamp(28px, 3.5vw, 44px);
    line-height: 1.1;
    color: var(--color-snow);
  }

  .vsec-text p {
    font-family: var(--font-sans);
    font-size: 17px;
    line-height: 1.75;
    color: var(--color-cream);
    margin-bottom: 16px;
  }

  .vsec-text p:last-child { margin-bottom: 0; }

  .vision-cta {
    padding-top: 72px;
    text-align: center;
  }

  .vision-cta p {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    font-size: clamp(20px, 2.5vw, 30px);
    color: var(--color-snow);
    margin-bottom: 28px;
  }

  @media (max-width: 900px) {
    .vision-quote-band { padding: 64px 24px 56px; }
    .vision-body { padding: 0 24px 80px; }
  }

  @media (max-width: 600px) {
    .vsec { padding: 44px 0; }
    .vsec-hd { gap: 14px; }
  }
</style>
