---
import Layout from '@/layouts/Layout.astro';

const title = 'Vision | SoundIn';
const description = 'SoundIn builds compliance infrastructure for UK nightlife. The Terrorism Act 2025 changes what operators need — we are building it.';

const sections = [
  {
    num: '01',
    heading: 'The state of the industry',
    body: [
      "Most venues in the UK still manage attendance with a clicker, log incidents in a notebook, and run guest lists from a WhatsApp thread. When something goes wrong — and in nightlife, things go wrong — there is no record, no data, and no accountability.",
      "That is not a technology problem. It is a safety problem wearing a technology mask.",
    ],
  },
  {
    num: '02',
    heading: "What's changing",
    body: [
      "New legislation now requires venues to meet formal compliance standards for the first time. Venue operators need documented procedures, trained staff, and verifiable records — not as a best practice, but as a legal requirement.",
      "Most venues are not ready. Most of the software that claims to help them is built for concerts and festivals, not the 11pm crowd at a 250-cap club in Glasgow.",
    ],
  },
  {
    num: '03',
    heading: "What we're building toward",
    body: [
      "A venue that can prove its headcount, log incidents in real time, and close a night with a clean financial record is not just legally compliant — it is a better place to work, a better place to operate, and a safer place to be.",
      "That is the standard we are building Holocron toward. One place for everything a venue operator actually needs, without the spreadsheets.",
    ],
  },
  {
    num: '04',
    heading: 'One product. One founder.',
    body: [
      "I built this from the Scottish Highlands because that's where I live. Not as a brand story, but as a fact that shapes how I work.",
      "Solo doesn't mean small. It means I have to be deliberate — deliberate about what goes in the product, deliberate about who I work with, deliberate about every hour spent.",
      "Say what you mean. Charge what the work costs. Own your mistakes. Take on less so you can do more with it. Build things that outlast the brief. Care about the people on the other side of every contract, and about the communities they operate in.",
    ],
  },
];

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': 'https://soundin.scot/vision#webpage',
  url: 'https://soundin.scot/vision',
  name: title,
  description,
  isPartOf: { '@id': 'https://soundin.scot/#organization' },
};
---

<Layout
  title={title}
  description={description}
  canonical="https://soundin.scot/vision"
  current="vision"
  skipLink={{ href: '#vision-content', label: 'Skip to content' }}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(aboutSchema)} slot="head" />

  <div class="page-hero" id="vision-content" tabindex="-1">
    <div class="page-hero-inner">
      <span class="page-hero-kicker">vision</span>
      <h1 class="page-hero-title">Safer venues.<br />Better nights.</h1>
      <p class="page-hero-desc">The UK night time economy has a technology problem. We're building the fix.</p>
    </div>
  </div>

  <div class="vision-quote-band">
    <blockquote class="vision-quote">
      <p>&ldquo;I&rsquo;d rather do fewer things properly than chase every brief that comes through the door.&rdquo;</p>
      <cite>Cougar Macdougall &mdash; Founder, SoundIn</cite>
    </blockquote>
  </div>

  <div class="vision-body">
    {sections.map((s) => (
      <section class="vsec">
        <header class="vsec-hd">
          <span class="vsec-num">{s.num}</span>
          <h2 class="vsec-title">{s.heading}</h2>
        </header>
        <div class="vsec-text">
          {s.body.map((p) => <p>{p}</p>)}
        </div>
      </section>
    ))}

    <div class="vision-cta">
      <p>Managing a venue?</p>
      <a href="/contact" class="cta-button">Get in touch <span aria-hidden="true">&rarr;</span></a>
    </div>
  </div>
</Layout>

<style>
  .vision-quote-band {
    padding: 88px 64px 72px;
    max-width: 960px;
    margin: 0 auto;
  }

  .vision-quote p {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    font-size: clamp(26px, 3.8vw, 50px);
    line-height: 1.2;
    color: var(--color-snow);
    margin-bottom: 20px;
    text-wrap: balance;
  }

  .vision-quote cite {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-style: normal;
  }

  .vision-body {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 64px 120px;
    border-top: 1px solid var(--color-ghost);
  }

  .vsec {
    padding: 60px 0;
    border-bottom: 1px solid var(--color-ghost);
  }

  .vsec-hd {
    display: flex;
    align-items: baseline;
    gap: 20px;
    margin-bottom: 24px;
  }

  .vsec-num {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    font-size: 22px;
    color: var(--color-salmon);
    flex-shrink: 0;
  }

  .vsec-title {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    font-size: clamp(28px, 3.5vw, 44px);
    line-height: 1.1;
    color: var(--color-snow);
  }

  .vsec-text p {
    font-family: var(--font-sans);
    font-size: 17px;
    line-height: 1.75;
    color: var(--color-cream);
    margin-bottom: 16px;
  }

  .vsec-text p:last-child { margin-bottom: 0; }

  .vision-cta {
    padding-top: 72px;
    text-align: center;
  }

  .vision-cta p {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    font-size: clamp(20px, 2.5vw, 30px);
    color: var(--color-snow);
    margin-bottom: 28px;
  }

  @media (max-width: 900px) {
    .vision-quote-band { padding: 64px 24px 56px; }
    .vision-body { padding: 0 24px 80px; }
  }

  @media (max-width: 600px) {
    .vsec { padding: 44px 0; }
    .vsec-hd { gap: 14px; }
  }
</style>
