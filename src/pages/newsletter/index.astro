---
import Layout from '@/layouts/Layout.astro';
import PageHeader from '@/components/PageHeader.astro';
import RevealScript from '@/components/RevealScript.astro';
import { getCollection } from 'astro:content';

const title = 'Newsletter: SoundIn | Notes from the Highlands';
const description = 'Quiet, irregular notes on building software, hosting events, and running a small agency from the Scottish Highlands. Subscribe or browse the archive.';

const posts = (await getCollection('newsletter')).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': 'https://soundin.scot/newsletter#blog',
  name: 'SoundIn Newsletter',
  description,
  url: 'https://soundin.scot/newsletter',
  publisher: { '@id': 'https://soundin.scot/#organization' },
  blogPost: posts.map((p) => ({
    '@type': 'BlogPosting',
    headline: p.data.title,
    description: p.data.summary,
    datePublished: p.data.publishedAt.toISOString(),
    url: `https://soundin.scot/newsletter/${p.id}`,
  })),
};

const dateFmt = new Intl.DateTimeFormat('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout
  title={title}
  description={description}
  canonical="https://soundin.scot/newsletter"
  current={null}
  skipLink={{ href: '#newsletter-signup', label: 'Skip to signup' }}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(blogSchema)} slot="head" />

  <PageHeader
    label="newsletter"
    headline="Quiet notes from"
    accent="the Highlands."
  />

  <section class="section signup-section" id="newsletter-signup" tabindex="-1">
    <div class="signup-card reveal">
      <div class="signup-text">
        <span class="section-num">01 / subscribe</span>
        <h2 class="section-headline">
          The announcement <span class="accent">goes here first.</span>
        </h2>
        <p class="section-sub">
          Event announcements, product launches, and the occasional honest write-up. Sent only when there&rsquo;s something worth your inbox.
        </p>
      </div>
      <form id="signup-form" class="signup-form" novalidate>
        <label for="signup-email" class="sr-only">Email address</label>
        <input
          id="signup-email"
          name="email"
          type="email"
          class="signup-input"
          placeholder="you@example.com"
          autocomplete="email"
          spellcheck="false"
          required
        />
        <button type="submit" class="cta-button">Subscribe <span aria-hidden="true">→</span></button>
        <p id="signup-status" class="signup-status" role="status" aria-live="polite"></p>
      </form>
    </div>
  </section>

  <section class="section archive-section">
    <div class="section-head reveal">
      <span class="section-num">02 / archive</span>
      <h2 class="section-headline">
        Past issues. <span class="accent">All of them.</span>
      </h2>
      <p class="section-sub">
        Indexed by issue number, oldest at the bottom. Each one stays online forever. No link rot.
      </p>
    </div>

    <ol class="archive-list reveal" reversed>
      {posts.map((p) => (
        <li class="archive-item">
          <a href={`/newsletter/${p.id}`} class="archive-link">
            <div class="archive-meta">
              <span class="archive-issue">№ {String(p.data.issue).padStart(2, '0')}</span>
              <time datetime={p.data.publishedAt.toISOString()} class="archive-date">
                {dateFmt.format(p.data.publishedAt)}
              </time>
            </div>
            <h3 class="archive-title">{p.data.title}</h3>
            <p class="archive-summary">{p.data.summary}</p>
            <span class="archive-cta">Read the issue <span aria-hidden="true">→</span></span>
          </a>
        </li>
      ))}
    </ol>
  </section>

  <RevealScript />
</Layout>

<style>
  .signup-section { padding-top: 80px; }

  .signup-card {
    max-width: 1280px;
    margin: 0 auto;
    padding: 80px 64px;
    border: 1px solid var(--color-ghost);
    border-radius: 24px;
    background: linear-gradient(180deg, rgba(255, 127, 107, 0.04) 0%, rgba(0, 0, 0, 0.2) 100%);
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 64px;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .signup-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at top right, rgba(255, 127, 107, 0.10) 0%, transparent 60%);
    pointer-events: none;
  }

  .signup-card > * { position: relative; z-index: 1; }

  .signup-text .section-num { margin-bottom: 24px; }
  .signup-text .section-headline { margin-bottom: 16px; font-size: clamp(32px, 4vw, 48px); }
  .signup-text .section-sub { max-width: 480px; }

  .signup-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: stretch;
  }

  .signup-input {
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid var(--color-faint);
    border-radius: 999px;
    padding: 16px 24px;
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--color-snow);
    transition: border-color 0.3s ease, background 0.3s ease;
  }

  .signup-input::placeholder { color: rgba(231, 223, 217, 0.4); }

  .signup-input:focus {
    outline: none;
    border-color: var(--color-salmon);
    background: rgba(0, 0, 0, 0.4);
  }

  .signup-form .cta-button {
    width: 100%;
    justify-content: center;
  }

  .signup-status {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--color-muted);
    min-height: 18px;
    text-align: center;
    margin: 0;
  }

  /* Archive */
  .archive-section { padding-top: 80px; }

  .archive-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-ghost);
  }

  .archive-item {
    border-bottom: 1px solid var(--color-ghost);
  }

  .archive-link {
    display: grid;
    grid-template-columns: 200px 1fr auto;
    gap: 32px;
    align-items: baseline;
    padding: 40px 0;
    transition: padding 0.3s ease;
  }

  .archive-link:hover { padding-left: 16px; }
  .archive-link:focus-visible {
    outline: 2px solid var(--color-salmon);
    outline-offset: 4px;
    border-radius: 4px;
  }

  .archive-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .archive-issue {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    font-size: 22px;
    color: var(--color-salmon);
  }

  .archive-date {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .archive-title {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    font-size: clamp(24px, 2.4vw, 32px);
    line-height: 1.2;
    color: var(--color-snow);
    margin-bottom: 8px;
    text-wrap: balance;
  }

  .archive-summary {
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-cream);
    max-width: 540px;
  }

  .archive-cta {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    align-self: center;
    transition: color 0.3s ease, gap 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .archive-link:hover .archive-cta { color: var(--color-salmon); gap: 10px; }

  @media (max-width: 900px) {
    .signup-card { grid-template-columns: 1fr; padding: 56px 32px; gap: 32px; }
    .archive-link { grid-template-columns: 1fr; gap: 8px; padding: 32px 0; }
    .archive-link:hover { padding-left: 0; }
    .archive-meta { flex-direction: row; align-items: baseline; gap: 16px; }
    .archive-cta { margin-top: 8px; }
  }
</style>

<script>
  const form = document.getElementById('signup-form') as HTMLFormElement | null;
  const input = document.getElementById('signup-email') as HTMLInputElement | null;
  const status = document.getElementById('signup-status');
  const button = form?.querySelector<HTMLButtonElement>('button');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!input || !status || !button) return;

    if (!input.value || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value)) {
      status.textContent = 'That doesn’t look like an email. Try again?';
      input.focus();
      return;
    }

    button.textContent = 'Subscribing…';
    button.disabled = true;
    status.textContent = '';

    // Replace with real endpoint when ready (Buttondown/Resend/HubSpot)
    await new Promise((resolve) => setTimeout(resolve, 900));
    status.textContent = 'You’re on the list. We’ll be in touch.';
    button.textContent = 'Subscribed';
    input.value = '';
  });
</script>
