---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';

const title = 'SoundIn: Scottish Digital Agency | Web, Events & Venue Software';
const description = 'SoundIn is a Scottish Highlands company building web applications, venue management software, and electronic music events in unique locations. Three founders. Six practices. One standard of care.';

type Pill = {
  label: string;
  href: string;
  external?: boolean;
  icon: 'vision' | 'agency' | 'ecosystem' | 'events' | 'contact' | 'newsletter' | 'surprise';
};

const pills: Pill[] = [
  { label: 'vision', href: '/vision', icon: 'vision' },
  { label: 'agency', href: '/agency', icon: 'agency' },
  { label: 'ecosystem', href: '/ecosystem', icon: 'ecosystem' },
  { label: 'events', href: '/events', icon: 'events' },
  { label: 'contact', href: '/contact', icon: 'contact' },
  { label: 'newsletter', href: '/newsletter', icon: 'newsletter' },
  { label: 'surprise me', href: '#surprise', icon: 'surprise' },
];

const newsletterPosts = await getCollection('newsletter');
const newsletterSlugs = newsletterPosts.map((p) => p.id);

type Suggestion = {
  id: string;
  group: 'Pages' | 'Newsletter';
  label: string;
  description: string;
  href: string;
  external?: boolean;
  keywords: string[];
};

const pageSuggestions: Suggestion[] = [
  {
    id: 'sug-vision',
    group: 'Pages',
    label: 'Vision',
    description: 'Mission, values, and the founder story.',
    href: '/vision',
    keywords: ['vision', 'about', 'mission', 'values', 'who', 'team', 'founders', 'story', 'cougar', 'emma', 'mark'],
  },
  {
    id: 'sug-agency',
    group: 'Pages',
    label: 'Agency',
    description: 'Web development, social media, marketing.',
    href: '/agency',
    keywords: ['agency', 'services', 'web', 'website', 'app', 'development', 'dev', 'next', 'nextjs', 'astro', 'social', 'marketing', 'instagram', 'tiktok', 'linkedin', 'content'],
  },
  {
    id: 'sug-ecosystem',
    group: 'Pages',
    label: 'Ecosystem',
    description: 'Holocron and the products in development.',
    href: '/ecosystem',
    keywords: ['ecosystem', 'product', 'products', 'holocron', 'venue', 'nightlife', 'club', 'ticketing', 'incidents', 'photon', 'lighting', 'dmx', 'saas'],
  },
  {
    id: 'sug-events',
    group: 'Pages',
    label: 'Events',
    description: 'Electronic music in unique Highland locations.',
    href: '/events',
    keywords: ['event', 'events', 'gig', 'club', 'music', 'electronic', 'rave', 'dj', 'highland', 'distillery', 'venue night'],
  },
  {
    id: 'sug-newsletter',
    group: 'Pages',
    label: 'Newsletter',
    description: 'Subscribe and read past issues.',
    href: '/newsletter',
    keywords: ['newsletter', 'subscribe', 'email', 'updates', 'archive', 'posts', 'writing', 'subscribe'],
  },
  {
    id: 'sug-contact',
    group: 'Pages',
    label: 'Contact',
    description: 'Send us an email or use the form.',
    href: '/contact',
    keywords: ['contact', 'hello', 'talk', 'reach', 'enquire', 'enquiry', 'email', 'message'],
  },
  {
    id: 'sug-holocron-ext',
    group: 'Pages',
    label: 'Holocron',
    description: 'holocron.scot — venue management SaaS.',
    href: 'https://holocron.scot',
    external: true,
    keywords: ['holocron', 'venue', 'nightlife', 'club', 'ticketing', 'incidents', 'guest list'],
  },
  {
    id: 'sug-privacy',
    group: 'Pages',
    label: 'Privacy notice',
    description: 'How we collect and use your data.',
    href: '/privacy',
    keywords: ['privacy', 'gdpr', 'data', 'cookies', 'legal'],
  },
];

const newsletterSuggestions: Suggestion[] = newsletterPosts
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .map((p) => ({
    id: `sug-news-${p.id}`,
    group: 'Newsletter' as const,
    label: p.data.title,
    description: p.data.summary,
    href: `/newsletter/${p.id}`,
    keywords: [...p.data.tags, p.data.title, p.data.summary]
      .join(' ')
      .toLowerCase()
      .split(/[^a-z0-9]+/)
      .filter((w) => w.length > 2),
  }));

const suggestions: Suggestion[] = [...pageSuggestions, ...newsletterSuggestions];

const orgSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['Organization', 'LocalBusiness'],
      '@id': 'https://soundin.scot/#organization',
      name: 'SoundIn',
      legalName: 'SoundIn Limited',
      url: 'https://soundin.scot',
      email: 'hello@soundin.scot',
      foundingDate: '2025',
      description: 'Scottish Highlands company delivering web development, venue management software, event production, lighting design, and social media management. Three founders, six practices, one standard of care.',
      identifier: { '@type': 'PropertyValue', name: 'Companies House', value: 'SC850719' },
      address: { '@type': 'PostalAddress', addressRegion: 'Highland', addressCountry: 'GB' },
      areaServed: [
        { '@type': 'Country', name: 'United Kingdom' },
        { '@type': 'AdministrativeArea', name: 'Scotland' },
      ],
      knowsAbout: ['Web Development', 'Digital Marketing', 'Event Production', 'Venue Management Software', 'DMX Lighting Control', 'Social Media Management'],
      sameAs: ['https://www.linkedin.com/company/soundin-ltd'],
    },
  ],
};
---

<Layout
  title={title}
  description={description}
  canonical="https://soundin.scot/"
  chrome="minimal"
  skipLink={{ href: '#portal-search', label: 'Skip to search' }}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} slot="head" />
  <script is:inline define:vars={{ slugs: newsletterSlugs, suggestions }}>
    window.__newsletterSlugs = slugs;
    window.__searchSuggestions = suggestions;
  </script>

  <main class="portal">
    <div class="portal-inner">
      <h1 class="portal-wordmark">
        <span class="logo-s">Sound</span><span class="logo-i">In</span>
      </h1>

      <p class="portal-tagline">
        <span class="gaelic">Fàilte.</span> What can we help you find?
      </p>

      <div class="portal-search-wrap">
        <form id="portal-search" class="portal-search" role="search" aria-label="Site search">
          <span class="portal-search-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="7"/>
              <path d="m21 21-4.3-4.3"/>
            </svg>
          </span>
          <input
            id="portal-search-input"
            name="q"
            type="text"
            class="portal-search-input"
            placeholder="e.g. events, holocron, who we are…"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            role="combobox"
            aria-label="Search the SoundIn site"
            aria-expanded="false"
            aria-controls="portal-search-listbox"
            aria-autocomplete="list"
          />
          <span id="portal-search-hint" class="portal-search-hint" aria-live="polite"></span>
        </form>
        <ul
          id="portal-search-listbox"
          class="portal-search-listbox"
          role="listbox"
          aria-label="Search suggestions"
          hidden
        ></ul>
      </div>

      <ul class="portal-pills" aria-label="Quick links">
        {pills.map((p) => (
          <li>
            <a
              class="portal-pill"
              href={p.href}
              data-href={p.href}
              data-label={p.label}
              rel={p.external ? 'noopener noreferrer' : undefined}
              target={p.external ? '_blank' : undefined}
            >
              <span class="portal-pill-icon" aria-hidden="true">
                {p.icon === 'vision' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
                    <circle cx="12" cy="12" r="3"/>
                  </svg>
                )}
                {p.icon === 'newsletter' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 4H6a2 2 0 0 0-2 2v14h16V6a2 2 0 0 0-2-2Z"/>
                    <path d="M8 8h8"/>
                    <path d="M8 12h8"/>
                    <path d="M8 16h5"/>
                  </svg>
                )}
                {p.icon === 'agency' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/>
                    <path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/>
                    <path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/>
                    <path d="M10 6h4"/>
                    <path d="M10 10h4"/>
                    <path d="M10 14h4"/>
                    <path d="M10 18h4"/>
                  </svg>
                )}
                {p.icon === 'ecosystem' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="1.2" fill="currentColor" stroke="none"/>
                    <ellipse cx="12" cy="12" rx="10" ry="4"/>
                    <ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(60 12 12)"/>
                    <ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(120 12 12)"/>
                  </svg>
                )}
                {p.icon === 'events' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2z"/>
                    <path d="M13 5v2"/>
                    <path d="M13 17v2"/>
                    <path d="M13 11v2"/>
                  </svg>
                )}
                {p.icon === 'contact' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"/>
                    <path d="m21.854 2.147-10.94 10.939"/>
                  </svg>
                )}
                {p.icon === 'surprise' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3 9.91 9.91 3 12l6.91 2.09L12 21l2.09-6.91L21 12l-6.91-2.09Z"/>
                    <path d="M5 3v4"/>
                    <path d="M19 17v4"/>
                    <path d="M3 5h4"/>
                    <path d="M17 19h4"/>
                  </svg>
                )}
              </span>
              <span>{p.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <footer class="portal-foot" aria-label="Site meta">
      <span>SoundIn Limited · SC850719</span>
      <a href="/privacy">Privacy</a>
      <a href="https://www.linkedin.com/company/soundin-ltd" rel="noopener noreferrer" target="_blank">LinkedIn ↗</a>
    </footer>
  </main>
</Layout>

<style>
  .portal {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 64px 24px 24px;
    background: #24302c;
  }

  .portal-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 720px;
    text-align: center;
    margin: auto;
  }

  .portal-wordmark {
    font-family: var(--font-sans);
    font-size: clamp(64px, 12vw, 144px);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 0.95;
    color: var(--color-snow);
    margin: 0 0 32px;
    opacity: 0;
    animation: enter 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  .portal-wordmark .logo-s {
    font-family: var(--font-sans);
    font-weight: 900;
  }

  .portal-wordmark .logo-i {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    color: var(--color-salmon);
  }

  .portal-tagline {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    font-size: clamp(20px, 2.4vw, 28px);
    color: rgba(231, 223, 217, 0.7);
    margin: 0 0 48px;
    opacity: 0;
    animation: enter 1s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
  }

  .portal-tagline .gaelic {
    color: var(--color-salmon);
  }

  /* Search */
  .portal-search-wrap {
    position: relative;
    width: 100%;
    margin-bottom: 32px;
    opacity: 0;
    animation: enter 1s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both;
    z-index: 5;
    isolation: isolate;
  }

  .portal-search {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    background: var(--color-snow);
    border-radius: 999px;
    padding: 4px 4px 4px 24px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25), 0 1px 0 rgba(255, 255, 255, 0.04);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .portal-search:focus-within {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), 0 0 0 3px rgba(255, 127, 107, 0.4);
  }

  .portal-search-icon {
    color: var(--color-scarab);
    opacity: 0.5;
    display: inline-flex;
    margin-right: 12px;
  }

  .portal-search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    padding: 16px 0;
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 400;
    color: var(--color-scarab);
    min-width: 0;
  }

  .portal-search-input::placeholder {
    color: rgba(36, 48, 44, 0.45);
    font-style: italic;
  }

  .portal-search-hint {
    position: absolute;
    bottom: -28px;
    left: 24px;
    right: 24px;
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-muted);
    text-align: left;
    pointer-events: none;
  }

  /* Listbox dropdown */
  .portal-search-listbox {
    position: absolute;
    top: calc(100% + 12px);
    left: 0;
    right: 0;
    list-style: none;
    margin: 0;
    padding: 8px;
    background: var(--color-snow);
    border-radius: 24px;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.35), 0 1px 0 rgba(255, 255, 255, 0.04);
    text-align: left;
    z-index: 50;
    isolation: isolate;
    overflow: hidden;
  }

  .portal-search-listbox[hidden] { display: none; }

  .portal-search-group {
    padding: 12px 16px 6px;
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(36, 48, 44, 0.45);
  }
  .portal-search-group:first-child { padding-top: 8px; }

  .portal-search-option {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      "label arrow"
      "desc arrow";
    column-gap: 12px;
    padding: 10px 16px;
    border-radius: 14px;
    cursor: pointer;
    transition: background 0.15s ease;
  }

  .portal-search-option:hover,
  .portal-search-option.is-active {
    background: rgba(255, 127, 107, 0.12);
  }

  .portal-search-option-label {
    grid-area: label;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 700;
    color: var(--color-scarab);
    line-height: 1.3;
  }

  .portal-search-option-desc {
    grid-area: desc;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 400;
    color: rgba(36, 48, 44, 0.65);
    line-height: 1.4;
    margin-top: 2px;
  }

  .portal-search-option-arrow {
    grid-area: arrow;
    align-self: center;
    font-family: var(--font-sans);
    font-size: 14px;
    color: rgba(36, 48, 44, 0.4);
    transition: color 0.15s ease, transform 0.15s ease;
  }

  .portal-search-option.is-active .portal-search-option-arrow,
  .portal-search-option:hover .portal-search-option-arrow {
    color: var(--color-salmon);
    transform: translateX(2px);
  }

  /* Pills */
  .portal-pills,
  .portal-foot {
    transition: opacity 0.2s ease, visibility 0.2s ease;
  }

  .portal.is-searching .portal-pills,
  .portal.is-searching .portal-foot {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .portal-pills {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    opacity: 0;
    animation: enter 1s cubic-bezier(0.16, 1, 0.3, 1) 0.7s both;
  }

  .portal-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border: 1px solid rgba(231, 223, 217, 0.15);
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 400;
    color: var(--color-snow);
    background: rgba(0, 0, 0, 0.15);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: border-color 0.3s ease, background 0.3s ease, transform 0.3s ease, color 0.3s ease;
  }

  .portal-pill:hover {
    border-color: var(--color-salmon);
    background: rgba(255, 127, 107, 0.12);
    color: var(--color-salmon);
    transform: translateY(-1px);
  }

  .portal-pill:focus-visible {
    outline: 2px solid var(--color-salmon);
    outline-offset: 4px;
  }

  .portal-pill-icon {
    display: inline-flex;
    color: currentColor;
    opacity: 0.8;
  }

  /* Footer meta */
  .portal-foot {
    position: relative;
    z-index: 1;
    margin-top: 64px;
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-muted);
    opacity: 0;
    animation: enter 1s cubic-bezier(0.16, 1, 0.3, 1) 0.9s both;
  }

  .portal-foot a { transition: color 0.3s ease; }
  .portal-foot a:hover { color: var(--color-snow); }
  .portal-foot a:focus-visible {
    color: var(--color-snow);
    outline: 2px solid var(--color-salmon);
    outline-offset: 4px;
    border-radius: 2px;
  }

  @media (max-width: 600px) {
    .portal { padding: 48px 16px 24px; }
    .portal-tagline { margin-bottom: 32px; }
    .portal-pills { gap: 8px; }
    .portal-pill { padding: 8px 14px; font-size: 13px; }
  }
</style>

<script>
  type Suggestion = {
    id: string;
    group: 'Pages' | 'Newsletter';
    label: string;
    description: string;
    href: string;
    external?: boolean;
    keywords: string[];
  };

  const suggestions: Suggestion[] =
    (window as unknown as { __searchSuggestions?: Suggestion[] }).__searchSuggestions ?? [];

  const input = document.getElementById('portal-search-input') as HTMLInputElement | null;
  const form = document.getElementById('portal-search') as HTMLFormElement | null;
  const hint = document.getElementById('portal-search-hint');
  const listbox = document.getElementById('portal-search-listbox') as HTMLUListElement | null;
  const portal = document.querySelector<HTMLElement>('main.portal');

  let activeIndex = -1;
  let visible: Suggestion[] = [];

  function score(s: Suggestion, q: string): number {
    const ql = q.toLowerCase().trim();
    if (!ql) return 0;
    const label = s.label.toLowerCase();
    const desc = s.description.toLowerCase();
    if (label === ql) return 100;
    if (label.startsWith(ql)) return 80;
    if (label.includes(ql)) return 60;
    if (s.keywords.some((k) => k.toLowerCase() === ql)) return 70;
    if (s.keywords.some((k) => k.toLowerCase().startsWith(ql))) return 50;
    if (s.keywords.some((k) => k.toLowerCase().includes(ql))) return 40;
    if (desc.includes(ql)) return 20;
    return 0;
  }

  function filter(query: string): Suggestion[] {
    if (!query.trim()) return [];
    return suggestions
      .map((s) => ({ s, score: score(s, query) }))
      .filter((x) => x.score > 0)
      .sort((a, b) => b.score - a.score)
      .slice(0, 6)
      .map((x) => x.s);
  }

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string),
    );
  }

  function render() {
    if (!listbox || !input) return;

    if (visible.length === 0) {
      listbox.hidden = true;
      listbox.innerHTML = '';
      input.setAttribute('aria-expanded', 'false');
      input.removeAttribute('aria-activedescendant');
      portal?.classList.remove('is-searching');
      return;
    }

    portal?.classList.add('is-searching');

    let html = '';
    let lastGroup = '';
    visible.forEach((s, i) => {
      if (s.group !== lastGroup) {
        html += `<li class="portal-search-group" role="presentation">${escapeHtml(s.group)}</li>`;
        lastGroup = s.group;
      }
      const isActive = i === activeIndex;
      html += `
        <li
          id="${s.id}"
          class="portal-search-option${isActive ? ' is-active' : ''}"
          role="option"
          aria-selected="${isActive}"
          data-href="${escapeHtml(s.href)}"
          data-external="${s.external ? '1' : ''}"
        >
          <span class="portal-search-option-label">${escapeHtml(s.label)}</span>
          <span class="portal-search-option-desc">${escapeHtml(s.description)}</span>
          <span class="portal-search-option-arrow" aria-hidden="true">${s.external ? '↗' : '→'}</span>
        </li>
      `;
    });

    listbox.innerHTML = html;
    listbox.hidden = false;
    input.setAttribute('aria-expanded', 'true');
    if (activeIndex >= 0 && visible[activeIndex]) {
      input.setAttribute('aria-activedescendant', visible[activeIndex].id);
    } else {
      input.removeAttribute('aria-activedescendant');
    }
  }

  function navigate(s: Suggestion) {
    if (s.external) {
      window.open(s.href, '_blank', 'noopener');
    } else {
      window.location.href = s.href;
    }
  }

  function close() {
    visible = [];
    activeIndex = -1;
    render();
  }

  function updateHint() {
    if (!hint || !input) return;
    if (visible.length > 0) {
      hint.textContent = '';
    } else if (input.value.trim()) {
      hint.textContent = 'No matches. Try a different word.';
    } else {
      hint.textContent = '';
    }
  }

  input?.addEventListener('input', () => {
    if (!input) return;
    visible = filter(input.value);
    activeIndex = visible.length > 0 ? 0 : -1;
    render();
    updateHint();
  });

  input?.addEventListener('focus', () => {
    if (!input) return;
    if (input.value.trim()) {
      visible = filter(input.value);
      activeIndex = visible.length > 0 ? 0 : -1;
      render();
      updateHint();
    }
  });

  input?.addEventListener('keydown', (e) => {
    if (visible.length === 0) return;
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeIndex = (activeIndex + 1) % visible.length;
      render();
      updateHint();
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeIndex = activeIndex <= 0 ? visible.length - 1 : activeIndex - 1;
      render();
      updateHint();
    } else if (e.key === 'Escape') {
      close();
      updateHint();
    }
  });

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!input?.contains(target) && !listbox?.contains(target)) close();
  });

  listbox?.addEventListener('mousedown', (e) => {
    const li = (e.target as HTMLElement).closest<HTMLLIElement>('li.portal-search-option');
    if (!li) return;
    e.preventDefault();
    const href = li.dataset.href;
    if (!href) return;
    navigate({
      id: li.id,
      group: 'Pages',
      label: '',
      description: '',
      href,
      external: li.dataset.external === '1',
      keywords: [],
    });
  });

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!input) return;

    if (activeIndex >= 0 && visible[activeIndex]) {
      navigate(visible[activeIndex]);
      return;
    }

    if (visible.length > 0) {
      navigate(visible[0]);
      return;
    }

    if (input.value.trim()) {
      window.location.href = '/agency';
    }
  });

  // Surprise me — picks a random newsletter issue
  const surprisePill = document.querySelector<HTMLAnchorElement>('a[data-label="surprise me"]');
  surprisePill?.addEventListener('click', (e) => {
    e.preventDefault();
    const slugs = (window as unknown as { __newsletterSlugs?: string[] }).__newsletterSlugs ?? [];
    if (slugs.length === 0) {
      window.location.href = '/newsletter';
      return;
    }
    const pick = slugs[Math.floor(Math.random() * slugs.length)];
    window.location.href = `/newsletter/${pick}`;
  });
</script>
