---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';

const title = 'SoundIn: Scottish Digital Agency | Web, Events & Venue Software';
const description = 'SoundIn is a Scottish Highlands company building web applications, venue management software, and electronic music events in unique locations. Three founders. Six practices. One standard of care.';

type Pill = {
  label: string;
  href: string;
  external?: boolean;
  icon: 'vision' | 'agency' | 'ecosystem' | 'events' | 'contact' | 'newsletter' | 'surprise';
};

const pills: Pill[] = [
  { label: 'vision', href: '/vision', icon: 'vision' },
  { label: 'agency', href: '/agency', icon: 'agency' },
  { label: 'ecosystem', href: '/ecosystem', icon: 'ecosystem' },
  { label: 'events', href: '/events', icon: 'events' },
  { label: 'contact', href: '/contact', icon: 'contact' },
  { label: 'newsletter', href: '/newsletter', icon: 'newsletter' },
  { label: 'surprise me', href: '#surprise', icon: 'surprise' },
];

const newsletterPosts = await getCollection('newsletter');
const newsletterSlugs = newsletterPosts.map((p) => p.id);

const orgSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['Organization', 'LocalBusiness'],
      '@id': 'https://soundin.scot/#organization',
      name: 'SoundIn',
      legalName: 'SoundIn Limited',
      url: 'https://soundin.scot',
      email: 'hello@soundin.scot',
      foundingDate: '2025',
      description: 'Scottish Highlands company delivering web development, venue management software, event production, lighting design, and social media management. Three founders, six practices, one standard of care.',
      identifier: { '@type': 'PropertyValue', name: 'Companies House', value: 'SC850719' },
      address: { '@type': 'PostalAddress', addressRegion: 'Highland', addressCountry: 'GB' },
      areaServed: [
        { '@type': 'Country', name: 'United Kingdom' },
        { '@type': 'AdministrativeArea', name: 'Scotland' },
      ],
      knowsAbout: ['Web Development', 'Digital Marketing', 'Event Production', 'Venue Management Software', 'DMX Lighting Control', 'Social Media Management'],
      sameAs: ['https://www.linkedin.com/company/soundin-ltd'],
    },
  ],
};
---

<Layout
  title={title}
  description={description}
  canonical="https://soundin.scot/"
  chrome="minimal"
  skipLink={{ href: '#portal-search', label: 'Skip to search' }}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} slot="head" />
  <script is:inline define:vars={{ slugs: newsletterSlugs }}>
    window.__newsletterSlugs = slugs;
  </script>

  <main class="portal">
    <div class="portal-inner">
      <h1 class="portal-wordmark">
        <span class="logo-s">Sound</span><span class="logo-i">In</span>
      </h1>

      <p class="portal-tagline">
        <span class="gaelic">Fàilte.</span> What can we help you find?
      </p>

      <form id="portal-search" class="portal-search" role="search" aria-label="Site search">
        <span class="portal-search-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="7"/>
            <path d="m21 21-4.3-4.3"/>
          </svg>
        </span>
        <input
          id="portal-search-input"
          name="q"
          type="search"
          class="portal-search-input"
          placeholder="e.g. events, holocron, who we are…"
          autocomplete="off"
          spellcheck="false"
          aria-label="Search the SoundIn site"
        />
        <span id="portal-search-hint" class="portal-search-hint" aria-live="polite"></span>
      </form>

      <ul class="portal-pills" aria-label="Quick links">
        {pills.map((p) => (
          <li>
            <a
              class="portal-pill"
              href={p.href}
              data-href={p.href}
              data-label={p.label}
              rel={p.external ? 'noopener noreferrer' : undefined}
              target={p.external ? '_blank' : undefined}
            >
              <span class="portal-pill-icon" aria-hidden="true">
                {p.icon === 'vision' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
                    <circle cx="12" cy="12" r="3"/>
                  </svg>
                )}
                {p.icon === 'newsletter' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 4H6a2 2 0 0 0-2 2v14h16V6a2 2 0 0 0-2-2Z"/>
                    <path d="M8 8h8"/>
                    <path d="M8 12h8"/>
                    <path d="M8 16h5"/>
                  </svg>
                )}
                {p.icon === 'agency' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/>
                    <path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/>
                    <path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/>
                    <path d="M10 6h4"/>
                    <path d="M10 10h4"/>
                    <path d="M10 14h4"/>
                    <path d="M10 18h4"/>
                  </svg>
                )}
                {p.icon === 'ecosystem' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="1.2" fill="currentColor" stroke="none"/>
                    <ellipse cx="12" cy="12" rx="10" ry="4"/>
                    <ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(60 12 12)"/>
                    <ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(120 12 12)"/>
                  </svg>
                )}
                {p.icon === 'events' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2z"/>
                    <path d="M13 5v2"/>
                    <path d="M13 17v2"/>
                    <path d="M13 11v2"/>
                  </svg>
                )}
                {p.icon === 'contact' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"/>
                    <path d="m21.854 2.147-10.94 10.939"/>
                  </svg>
                )}
                {p.icon === 'surprise' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3 9.91 9.91 3 12l6.91 2.09L12 21l2.09-6.91L21 12l-6.91-2.09Z"/>
                    <path d="M5 3v4"/>
                    <path d="M19 17v4"/>
                    <path d="M3 5h4"/>
                    <path d="M17 19h4"/>
                  </svg>
                )}
              </span>
              <span>{p.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <footer class="portal-foot" aria-label="Site meta">
      <span>SoundIn Limited · SC850719</span>
      <a href="/privacy">Privacy</a>
      <a href="https://www.linkedin.com/company/soundin-ltd" rel="noopener noreferrer" target="_blank">LinkedIn ↗</a>
    </footer>
  </main>
</Layout>

<style>
  .portal {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 64px 24px 24px;
    background: #24302c;
  }

  .portal-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 720px;
    text-align: center;
    margin: auto;
  }

  .portal-wordmark {
    font-family: var(--font-sans);
    font-size: clamp(64px, 12vw, 144px);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 0.95;
    color: var(--color-snow);
    margin: 0 0 32px;
    opacity: 0;
    animation: enter 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  .portal-wordmark .logo-s {
    font-family: var(--font-sans);
    font-weight: 900;
  }

  .portal-wordmark .logo-i {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    color: var(--color-salmon);
  }

  .portal-tagline {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    font-size: clamp(20px, 2.4vw, 28px);
    color: rgba(231, 223, 217, 0.7);
    margin: 0 0 48px;
    opacity: 0;
    animation: enter 1s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
  }

  .portal-tagline .gaelic {
    color: var(--color-salmon);
  }

  /* Search */
  .portal-search {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    background: var(--color-snow);
    border-radius: 999px;
    padding: 4px 4px 4px 24px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25), 0 1px 0 rgba(255, 255, 255, 0.04);
    margin-bottom: 32px;
    opacity: 0;
    animation: enter 1s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .portal-search:focus-within {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), 0 0 0 3px rgba(255, 127, 107, 0.4);
  }

  .portal-search-icon {
    color: var(--color-scarab);
    opacity: 0.5;
    display: inline-flex;
    margin-right: 12px;
  }

  .portal-search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    padding: 16px 0;
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 400;
    color: var(--color-scarab);
    min-width: 0;
  }

  .portal-search-input::placeholder {
    color: rgba(36, 48, 44, 0.45);
    font-style: italic;
  }

  .portal-search-hint {
    position: absolute;
    bottom: -28px;
    left: 24px;
    right: 24px;
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-muted);
    text-align: left;
    pointer-events: none;
  }

  /* Pills */
  .portal-pills {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    opacity: 0;
    animation: enter 1s cubic-bezier(0.16, 1, 0.3, 1) 0.7s both;
  }

  .portal-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border: 1px solid rgba(231, 223, 217, 0.15);
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 400;
    color: var(--color-snow);
    background: rgba(0, 0, 0, 0.15);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: border-color 0.3s ease, background 0.3s ease, transform 0.3s ease, color 0.3s ease;
  }

  .portal-pill:hover {
    border-color: var(--color-salmon);
    background: rgba(255, 127, 107, 0.12);
    color: var(--color-salmon);
    transform: translateY(-1px);
  }

  .portal-pill:focus-visible {
    outline: 2px solid var(--color-salmon);
    outline-offset: 4px;
  }

  .portal-pill-icon {
    display: inline-flex;
    color: currentColor;
    opacity: 0.8;
  }

  /* Footer meta */
  .portal-foot {
    position: relative;
    z-index: 1;
    margin-top: 64px;
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-muted);
    opacity: 0;
    animation: enter 1s cubic-bezier(0.16, 1, 0.3, 1) 0.9s both;
  }

  .portal-foot a { transition: color 0.3s ease; }
  .portal-foot a:hover { color: var(--color-snow); }
  .portal-foot a:focus-visible {
    color: var(--color-snow);
    outline: 2px solid var(--color-salmon);
    outline-offset: 4px;
    border-radius: 2px;
  }

  @media (max-width: 600px) {
    .portal { padding: 48px 16px 24px; }
    .portal-tagline { margin-bottom: 32px; }
    .portal-pills { gap: 8px; }
    .portal-pill { padding: 8px 14px; font-size: 13px; }
  }
</style>

<script>
  type Route = { keywords: string[]; href: string; label: string };

  const routes: Route[] = [
    { keywords: ['vision', 'about', 'mission', 'values', 'who', 'team', 'founders', 'story'], href: '/vision', label: 'vision' },
    { keywords: ['agency', 'services', 'offerings', 'web', 'website', 'app', 'application', 'development', 'dev', 'frontend', 'next', 'astro', 'social', 'marketing', 'instagram', 'tiktok', 'linkedin'], href: '/agency', label: 'agency' },
    { keywords: ['ecosystem', 'product', 'products', 'holocron', 'venue', 'nightlife', 'club', 'ticketing', 'incidents', 'photon', 'lighting', 'dmx'], href: '/ecosystem', label: 'ecosystem' },
    { keywords: ['event', 'events', 'gig', 'club night', 'music', 'electronic', 'rave', 'dj', 'venue night'], href: '/events', label: 'events' },
    { keywords: ['newsletter', 'subscribe', 'email list', 'updates', 'archive', 'posts', 'writing'], href: '/newsletter', label: 'newsletter' },
    { keywords: ['contact', 'hello', 'talk', 'reach', 'enquire', 'enquiry'], href: '/contact', label: 'contact' },
    { keywords: ['privacy', 'gdpr', 'data'], href: '/privacy', label: 'privacy' },
  ];

  const input = document.getElementById('portal-search-input') as HTMLInputElement | null;
  const form = document.getElementById('portal-search') as HTMLFormElement | null;
  const hint = document.getElementById('portal-search-hint');

  function findRoute(query: string): Route | null {
    const q = query.toLowerCase().trim();
    if (!q) return null;
    for (const r of routes) {
      if (r.keywords.some((k) => q.includes(k))) return r;
    }
    return null;
  }

  function updateHint() {
    if (!input || !hint) return;
    const r = findRoute(input.value);
    hint.textContent = r ? `↵ go to ${r.label}` : '';
  }

  input?.addEventListener('input', updateHint);

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!input) return;
    const r = findRoute(input.value);
    if (r) {
      if (r.href.startsWith('http')) {
        window.open(r.href, '_blank', 'noopener');
      } else {
        window.location.href = r.href;
      }
    } else if (input.value.trim()) {
      window.location.href = '/practices';
    }
  });

  // Surprise me — picks a random newsletter issue
  const surprisePill = document.querySelector<HTMLAnchorElement>('a[data-label="surprise me"]');
  surprisePill?.addEventListener('click', (e) => {
    e.preventDefault();
    const slugs = (window as unknown as { __newsletterSlugs?: string[] }).__newsletterSlugs ?? [];
    if (slugs.length === 0) {
      window.location.href = '/newsletter';
      return;
    }
    const pick = slugs[Math.floor(Math.random() * slugs.length)];
    window.location.href = `/newsletter/${pick}`;
  });
</script>
