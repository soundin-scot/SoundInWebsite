---
import Layout from '@/layouts/Layout.astro';
import PageHeader from '@/components/PageHeader.astro';
import RevealScript from '@/components/RevealScript.astro';

const title = 'Events: SoundIn | Electronic Music in Unique Highland Locations';
const description = 'SoundIn hosts electronic music events in unique locations across the Scottish Highlands and beyond. Sign up for the next announcement.';

const principles = [
  {
    label: '01',
    head: 'Place first',
    body: 'We pick the room before the lineup. Old halls, distilleries, glasshouses, hill-top crofts. The venue is the headline as much as the act.',
  },
  {
    label: '02',
    head: 'Sound that respects the space',
    body: 'Our own rig, tuned for the room, run by people who know the difference between loud and present. No one-size-fits-all PA dropped in.',
  },
  {
    label: '03',
    head: 'Small enough to feel right',
    body: 'Capacities sized to the venue, not the spreadsheet. You can walk to the bar without queueing. You can hear the person next to you between tracks.',
  },
  {
    label: '04',
    head: 'Local first, then further',
    body: 'Highland artists on the bill before international names. We promote talent that lives here. The travelling acts come because they want to play these rooms.',
  },
];
---

<Layout
  title={title}
  description={description}
  canonical="https://soundin.scot/events"
  current={null}
  skipLink={{ href: '#events-content', label: 'Skip to content' }}
>
  <PageHeader
    label="events"
    headline="Electronic music in places you wouldn't"
    accent="usually find it."
  />

  <section class="section" id="events-content" tabindex="-1">
    <div class="section-head reveal">
      <span class="section-num">01 / what we host</span>
      <h2 class="section-headline">
        The venue comes first. <span class="accent">Everything else follows.</span>
      </h2>
      <p class="section-sub">
        SoundIn hosts electronic music events in rooms most promoters wouldn&rsquo;t book: old halls, distilleries, lochside venues, and the occasional surprise. The location is the brief.
      </p>
    </div>

    <div class="events-principles reveal">
      {principles.map((p) => (
        <div class="event-principle">
          <span class="event-principle-num">{p.label}</span>
          <h3 class="event-principle-head">{p.head}</h3>
          <p class="event-principle-body">{p.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="section events-next">
    <div class="events-next-inner reveal">
      <span class="section-num">02 / next event</span>
      <h2 class="section-headline">
        The next one <span class="accent">isn&rsquo;t announced yet.</span>
      </h2>
      <p class="section-sub">
        We don&rsquo;t advertise dates until tickets are ready to sell. The newsletter goes out first, before social media, before anything else.
      </p>
    </div>
  </section>

  <section class="section cta-section">
    <div class="cta-card reveal">
      <span class="section-num">03 / be there next time</span>
      <h2 class="cta-headline">Get the announcement before tickets go public.</h2>
      <p class="cta-sub">Subscribers see the date, the venue, and the lineup before social media does. No spam, no filler. Only when there&rsquo;s something to share.</p>
      <div class="cta-actions">
        <a href="/newsletter" class="cta-button">Subscribe to the newsletter <span aria-hidden="true">→</span></a>
        <a href="mailto:hello@soundin.scot" class="cta-secondary">or email us directly</a>
      </div>
    </div>
  </section>

  <RevealScript />
</Layout>

<style>
  .events-principles {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border-top: 1px solid var(--color-ghost);
  }

  .event-principle {
    padding: 56px 48px;
    border-bottom: 1px solid var(--color-ghost);
    border-right: 1px solid var(--color-ghost);
  }

  .event-principle:nth-child(2n) { border-right: none; }

  .event-principle-num {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--color-salmon);
    margin-bottom: 16px;
  }

  .event-principle-head {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    font-size: clamp(24px, 2.4vw, 32px);
    line-height: 1.1;
    color: var(--color-snow);
    margin-bottom: 16px;
    text-wrap: balance;
  }

  .event-principle-body {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.7;
    color: var(--color-cream);
  }

  .events-next {
    border-top: 1px solid var(--color-ghost);
  }

  .events-next-inner {
    max-width: 880px;
  }

  @media (max-width: 900px) {
    .events-principles { grid-template-columns: 1fr; }
    .event-principle { padding: 40px 24px; border-right: none; }
  }
</style>
