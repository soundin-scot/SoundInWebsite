---
import Layout from '@/layouts/Layout.astro';

const title = 'Contact SoundIn';
const description = 'Get in touch. Based in the Scottish Highlands - we build compliance-first software for the UK night time economy. Email, or use the form.';

const pageSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ContactPage',
      '@id': 'https://soundin.scot/contact/#webpage',
      url: 'https://soundin.scot/contact/',
      name: 'Contact SoundIn',
      isPartOf: { '@id': 'https://soundin.scot/#organization' },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://soundin.scot/' },
        { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://soundin.scot/contact/' },
      ],
    },
  ],
};
---

<Layout
  title={title}
  description={description}
  canonical="https://soundin.scot/contact/"
  current="contact"
  skipLink={{ href: '#contact-form', label: 'Skip to contact form' }}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(pageSchema)} slot="head" />

  <div class="page-hero">
    <div class="page-hero-inner">
      <span class="page-hero-kicker">contact</span>
      <h1 class="page-hero-title">Get in touch</h1>
      <p class="page-hero-desc">Running a venue, building something adjacent, or just want to know more — get in touch.</p>
    </div>
  </div>

  <section class="contact" id="contact-form">
    <div>
      <form id="contact-form-el">
        <div class="field-group">
          <label for="contact-name" class="field-label">Name</label>
          <input id="contact-name" name="name" class="contact-field" type="text" autocomplete="name" required />
        </div>
        <div class="field-group">
          <label for="contact-email" class="field-label">Email</label>
          <input id="contact-email" name="email" class="contact-field" type="email" autocomplete="email" spellcheck="false" required />
        </div>
        <div class="field-group">
          <label for="contact-company" class="field-label">Company</label>
          <input id="contact-company" name="company" class="contact-field" type="text" autocomplete="organization" />
        </div>
        <div class="field-group">
          <label for="contact-message" class="field-label">Message</label>
          <textarea id="contact-message" name="message" class="contact-field" rows="4" required></textarea>
        </div>
        <button class="contact-submit" type="submit">Send</button>
        <div id="form-status" role="status" aria-live="polite"></div>
      </form>
    </div>
    <div class="contact-right">
      <dl>
        <div class="contact-info-group">
          <dt class="contact-info-label">General</dt>
          <dd class="contact-info-val"><a href="mailto:hello@soundin.scot">hello@soundin.scot</a></dd>
        </div>
        <div class="contact-info-group">
          <dt class="contact-info-label">Location</dt>
          <dd class="contact-info-val">Scottish Highlands, UK</dd>
        </div>
        <div class="contact-info-group">
          <dt class="contact-info-label">Socials</dt>
          <dd class="contact-info-val"><a href="https://www.linkedin.com/company/soundin-ltd" rel="noopener noreferrer" target="_blank">LinkedIn</a></dd>
        </div>
      </dl>
    </div>
  </section>
</Layout>

<style>
  .contact {
    position: relative;
    z-index: 1;
    max-width: 1000px;
    margin: 0 auto;
    padding: 80px 64px 120px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .field-group { margin-bottom: 0; }

  .field-label {
    display: block;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    padding-top: 16px;
    margin-bottom: 0;
  }

  .contact-field {
    display: block;
    width: 100%;
    background: none;
    border: none;
    border-bottom: 1px solid var(--color-faint);
    padding: 8px 0 16px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 400;
    color: var(--color-snow);
    transition: border-color 0.3s ease;
  }

  textarea.contact-field { resize: none; }
  .contact-field::placeholder { color: rgba(231, 223, 217, 0.3); }
  [data-theme="light"] .contact-field::placeholder { color: rgba(36, 48, 44, 0.3); }

  .contact-field:focus-visible {
    border-color: var(--color-salmon);
    outline: 2px solid rgba(255, 127, 107, 0.4);
    outline-offset: 4px;
  }

  .contact-submit {
    margin-top: 40px;
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--color-scarab);
    background: var(--color-salmon);
    border: none;
    border-radius: 999px;
    padding: 16px 32px;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .contact-submit:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(255, 127, 107, 0.3);
  }

  .contact-submit:focus-visible {
    outline: 2px solid var(--color-snow);
    outline-offset: 4px;
  }

  .contact-submit:disabled {
    opacity: 0.6;
    cursor: default;
    transform: none;
    box-shadow: none;
  }

  .contact-right { padding-top: 24px; }

  .contact-info-group { margin-bottom: 40px; }

  .contact-info-label {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    font-size: 18px;
    color: var(--color-salmon);
    margin-bottom: 4px;
  }

  .contact-info-val {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 400;
    color: var(--color-cream);
  }

  .contact-info-val a { transition: opacity 0.3s ease; }
  .contact-info-val a:hover { opacity: 0.6; }
  .contact-info-val a:focus-visible {
    outline: 2px solid var(--color-salmon);
    outline-offset: 4px;
    border-radius: 2px;
  }

  #form-status {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--color-muted);
    margin-top: 12px;
    min-height: 20px;
  }

  @media (max-width: 900px) {
    .contact { grid-template-columns: 1fr; padding: 64px 24px 80px; gap: 48px; }
    .contact-right { padding-top: 0; }
  }
</style>

<script>
  const form = document.getElementById('contact-form-el') as HTMLFormElement | null;
  const ta = document.getElementById('contact-message') as HTMLTextAreaElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector<HTMLButtonElement>('.contact-submit');
    const status = document.getElementById('form-status');
    if (!btn || !status) return;

    const name = (form.querySelector<HTMLInputElement>('#contact-name'))?.value ?? '';
    const email = (form.querySelector<HTMLInputElement>('#contact-email'))?.value ?? '';
    const company = (form.querySelector<HTMLInputElement>('#contact-company'))?.value ?? '';
    const message = (form.querySelector<HTMLTextAreaElement>('#contact-message'))?.value ?? '';

    btn.textContent = 'Sending…';
    btn.disabled = true;
    status.textContent = '';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, company, message }),
      });

      if (!res.ok) {
        throw new Error(`HTTP ${res.status}`);
      }

      btn.textContent = 'Sent';
      status.textContent = "We'll be in touch.";
      form.reset();
    } catch (err) {
      console.error('Contact form error:', err);
      btn.textContent = 'Send Message';
      btn.disabled = false;
      status.textContent = 'Something went wrong. Email us at hello@soundin.scot';
    }
  });

  ta?.addEventListener('input', () => {
    ta.style.height = 'auto';
    ta.style.height = ta.scrollHeight + 'px';
  });
</script>
