---
import Logo from './Logo.astro';
type NavKey = 'vision' | 'ecosystem' | 'newsletter' | 'contact' | null;
interface Props {
  current?: NavKey;
}
const { current = null } = Astro.props;

const links: { key: Exclude<NavKey, null>; label: string; href: string }[] = [
  { key: 'vision', label: 'vision', href: '/vision' },
  { key: 'ecosystem', label: 'products', href: '/ecosystem' },
  { key: 'newsletter', label: 'newsletter', href: '/newsletter' },
  { key: 'contact', label: 'contact', href: '/contact' },
];
---

<nav class="nav fixed top-0 left-0 right-0 z-[100] flex items-center justify-between px-6 h-20 border-b border-transparent transition-[background,border-color] duration-500">
  <a href="/" class="nav-home" aria-label="SoundIn home">
    <Logo />
  </a>
  <ul class="nav-links flex gap-8 list-none max-[1100px]:gap-5">
    {links.map((l, i) => (
      <li class={i < links.length - 1 ? 'nav-hide-mobile' : ''}>
        <a href={l.href} aria-current={current === l.key ? 'page' : undefined}>{l.label}</a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .nav-home {
    display: inline-flex;
    align-items: center;
    color: var(--color-snow);
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 900;
    letter-spacing: 0.01em;
    transition: opacity 0.3s ease;
  }
  .nav-home:hover { opacity: 0.7; }
  .nav-home:focus-visible {
    outline: 2px solid var(--color-salmon);
    outline-offset: 4px;
    border-radius: 2px;
  }
  .nav-home :global(.logo) {
    font-size: 18px;
  }
  .nav.scrolled {
    background: rgba(36, 48, 44, 0.4);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom-color: rgba(231, 223, 217, 0.04);
  }
  .nav-links a {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 400;
    color: var(--color-snow);
    transition: opacity 0.3s ease;
  }
  .nav-hide-mobile { }
  @media (max-width: 800px) {
    .nav-hide-mobile { display: none; }
  }
  .nav-links a[aria-current="page"] { opacity: 0.6; }
  .nav-links a:hover { opacity: 0.6; }
  .nav-links a:focus-visible {
    opacity: 0.6;
    outline: 2px solid var(--color-salmon);
    outline-offset: 4px;
    border-radius: 2px;
  }
</style>

<script>
  const nav = document.querySelector('.nav');
  if (nav) {
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          nav.classList.toggle('scrolled', window.scrollY > 40);
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }
</script>
