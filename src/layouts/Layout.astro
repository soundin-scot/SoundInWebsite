---
import '@/styles/global.css';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogType?: 'website' | 'article';
  current?: 'vision' | 'agency' | 'ecosystem' | 'events' | 'newsletter' | 'contact' | null;
  skipLink?: { href: string; label: string };
  chrome?: 'full' | 'minimal';
}

const {
  title,
  description,
  canonical,
  ogType = 'website',
  current = null,
  skipLink,
  chrome = 'full',
} = Astro.props;

const ogImage = 'https://soundin.scot/og-image.png';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#24302c" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonical} />

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="SoundIn" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_GB" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="geo.region" content="GB-SCT" />
    <meta name="geo.placename" content="Scottish Highlands" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="/fonts/negara-serif-hairline-italic.woff2" as="font" type="font/woff2" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Lexend+Deca:wght@400;700;900&display=swap"
    />

    <slot name="head" />
  </head>
  <body>
    {skipLink && (
      <a href={skipLink.href} class="sr-only skip-link">{skipLink.label}</a>
    )}

    {chrome === 'full' && <Nav current={current} />}

    <slot />

    {chrome === 'full' && <Footer />}
  </body>
</html>
